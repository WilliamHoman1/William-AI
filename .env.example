# Copy to .env.local for local dev (`vercel dev` loads it automatically).
# In production, set these in Vercel → Settings → Environment Variables.

# Required — powers the AI chat (console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional — natural TTS voice for spoken replies (elevenlabs.io).
# Without these, replies fall back to the browser's built-in voices.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional — site-wide daily Claude token budget (cost guardrail). Once hit,
# /api/chat stops calling Claude and returns a canned reply instead. Needs an
# Upstash Redis database connected via Vercel's Storage/Marketplace tab.
# NOTE: Vercel prefixes the injected vars with your database's name, e.g.
# connecting a database named "TokenTracking" injects TokenTracking_KV_REST_API_URL
# and TokenTracking_KV_REST_API_TOKEN, not the plain names below. Run
# `vercel env pull` and check the actual names if the budget check isn't
# recording usage — api/chat.js checks a few common variants but you may
# need to add its exact prefix there.
MAX_DAILY_TOKENS=
KV_REST_API_URL=
KV_REST_API_TOKEN=
