# Copy to .env.local for local dev (`vercel dev` loads it automatically).
# In production, set these in Vercel → Settings → Environment Variables.

# Required — powers the AI chat (console.anthropic.com)
ANTHROPIC_API_KEY=

# Optional — natural TTS voice for spoken replies (elevenlabs.io).
# Without these, replies fall back to the browser's built-in voices.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
